// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Developer's registered iOS app
model App {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  name             String
  companyName      String?            // Developer's company/business name
  supportEmail     String?            // End-customer support email
  bundleId         String   @unique   // e.g. "com.acme.myapp"
  clerkUserId      String             // Developer's Clerk user ID

  // Payment provider
  paymentProvider  PaymentProvider @default(STRIPE)

  // Stripe Connect account for payouts to developer
  stripeConnectId  String?  @unique   // e.g. "acct_xxx" (Phase 2)

  // Rootline account (alternative payment provider)
  rootlineAccountId String?  @unique

  // App mode
  mode             String   @default("sandbox")  // "sandbox" | "live"

  // Apple DMA entitlement status
  dmaEntitlementConfirmed Boolean @default(false)

  // Onboarding
  revenueTier      String?            // e.g. "<1k", "1k-10k", "10k-100k", ">100k"
  plan             String?            // "managed" | "byos"

  // Webhook settings
  webhookUrl       String?
  webhookSecret    String?

  // Apple App Store Connect credentials (for DMA reporting)
  appleKeyId       String?
  appleIssuerId    String?
  applePrivateKey  String?
  appleBundleId    String?

  // DMA compliance setup
  setupChecklist                 Json?       // JSONB checklist state
  iapExclusivityAcknowledgedAt   DateTime?

  // End-customer email preferences
  sendCustomerEmails Boolean @default(true)

  // Custom pricing (admin-managed)
  platformFeePercent   Float     @default(1.5)
  platformFeeUpdatedAt DateTime?

  // Alerting
  lastWebhookAlertAt             DateTime?

  products         Product[]
  apiKeys          ApiKey[]
  customers        Customer[]
  transactions     Transaction[]
  gdprAuditLogs    GdprAuditLog[]
  promotions       Promotion[]

  @@index([clerkUserId])
}

// Developer's API keys for SDK authentication
model ApiKey {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?

  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  keyPrefix   String   // First 8 chars (for display)
  keyHash     String   @unique // SHA-256 of full key
  name        String   // e.g. "Production", "Development"
  isActive    Boolean  @default(true)

  @@index([appId])
}

// Products/subscriptions configured in EUPay
model Product {
  id               String      @id @default(cuid())
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  appId            String
  app              App         @relation(fields: [appId], references: [id], onDelete: Cascade)

  name             String      // e.g. "Pro Monthly"
  description      String?
  productType      ProductType // ONE_TIME | SUBSCRIPTION

  // App Store product ID (for cross-referencing StoreKit)
  appStoreProductId String?

  // Stripe Price ID
  stripePriceId    String      @unique
  stripeProductId  String

  // Pricing
  amountCents      Int         // Price in cents (excluding VAT)
  currency         String      @default("eur")

  // Subscription fields (null for one-time)
  interval         String?     // "month" | "year"
  intervalCount    Int?        @default(1)
  trialDays        Int?        @default(0)

  isActive         Boolean     @default(true)

  entitlements     Entitlement[]
  transactions     Transaction[]
  promotions       Promotion[]

  @@index([appId])
  @@index([stripePriceId])
}

// End-user of the developer's app
model Customer {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appId           String
  app             App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  // Developer's own user ID (passed in SDK config)
  externalUserId  String

  // Stripe customer
  stripeCustomerId String  @unique

  // PII (GDPR: can be anonymised on deletion request)
  email           String?
  name            String?

  // GDPR
  gdprConsentAt   DateTime?
  withdrawalWaivedAt DateTime?  // Widerrufsrecht waiver timestamp
  deletedAt       DateTime?     // Soft delete for GDPR erasure

  // Location (for VAT)
  countryCode     String?     // e.g. "DE", "FR"

  entitlements    Entitlement[]
  transactions    Transaction[]
  promotionRedemptions PromotionRedemption[]

  @@unique([appId, externalUserId])
  @@index([appId])
  @@index([stripeCustomerId])
}

// Active product access
model Entitlement {
  id              String            @id @default(cuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  customerId      String
  customer        Customer          @relation(fields: [customerId], references: [id])

  productId       String
  product         Product           @relation(fields: [productId], references: [id])

  status          EntitlementStatus // ACTIVE | EXPIRED | CANCELLED | PAUSED
  source          EntitlementSource // WEB_CHECKOUT | STOREKIT (future)

  // Subscription details
  stripeSubscriptionId String?       @unique
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean        @default(false)

  // One-time purchase
  expiresAt       DateTime?         // null = lifetime

  @@index([customerId])
  @@index([productId])
  @@index([stripeSubscriptionId])
}

// Payment transactions
model Transaction {
  id                String          @id @default(cuid())
  createdAt         DateTime        @default(now())

  appId             String
  app               App             @relation(fields: [appId], references: [id])

  customerId        String
  customer          Customer        @relation(fields: [customerId], references: [id])

  productId         String
  product           Product         @relation(fields: [productId], references: [id])

  // Stripe references
  stripePaymentIntentId String?     @unique
  stripeInvoiceId       String?     @unique
  stripeCheckoutSessionId String?   @unique

  // Amounts (in cents)
  amountTotal       Int             // Total charged (inc. VAT)
  amountSubtotal    Int             // Pre-tax amount
  amountTax         Int             // VAT amount
  vatRate           Float?          // e.g. 0.19 for Germany
  vatCountry        String?         // "DE"
  currency          String          @default("eur")

  status            TransactionStatus // PENDING | SUCCEEDED | REFUNDED | DISPUTED

  // German consumer law
  withdrawalWaivedAt DateTime?

  // Apple DMA external purchase reporting
  appleExternalPurchaseToken String?
  appleReportStatus          AppleReportStatus?
  appleReportedAt            DateTime?
  appleReportError           String?

  promotionRedemptions PromotionRedemption[]

  @@index([appId])
  @@index([customerId])
  @@index([appleReportStatus])
}

// Stripe webhook events log (for debugging + idempotency)
model WebhookEvent {
  id          String   @id // Stripe event ID (e.g. "evt_xxx")
  createdAt   DateTime @default(now())
  processedAt DateTime?

  type        String   // e.g. "checkout.session.completed"
  appId       String?
  payload     Json     // Full Stripe event object
  status      WebhookStatus @default(PENDING)
  error       String?
}

enum PaymentProvider {
  STRIPE
  ROOTLINE
}

enum ProductType {
  ONE_TIME
  SUBSCRIPTION
}

enum EntitlementStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAUSED
}

enum EntitlementSource {
  WEB_CHECKOUT
  STOREKIT
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  REFUNDED
  DISPUTED
}

enum WebhookStatus {
  PENDING
  PROCESSED
  FAILED
}

enum AppleReportStatus {
  PENDING
  REPORTED
  FAILED
}

// GDPR audit log
model GdprAuditLog {
  id          String   @id @default(cuid())
  appId       String
  action      String   // 'EXPORT' | 'DELETE'
  userId      String   // externalUserId of the affected customer
  requestedBy String   // clerkUserId of the developer who triggered it
  ip          String?
  createdAt   DateTime @default(now())
  app         App      @relation(fields: [appId], references: [id])

  @@index([appId])
}

// DMA regulatory updates feed
model RegulatoryUpdate {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  publishedAt   DateTime @default(now())

  title         String
  description   String
  actionRequired String?

  reads         RegulatoryUpdateRead[]
}

model RegulatoryUpdateRead {
  id           String   @id @default(cuid())
  readAt       DateTime @default(now())

  updateId     String
  update       RegulatoryUpdate @relation(fields: [updateId], references: [id], onDelete: Cascade)

  clerkUserId  String

  @@unique([updateId, clerkUserId])
  @@index([clerkUserId])
}

// Promotions / coupons
model Promotion {
  id               String          @id @default(cuid())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  appId            String
  app              App             @relation(fields: [appId], references: [id], onDelete: Cascade)

  name             String          // Internal name (e.g. "Launch 20% off")
  code             String?         // Public promo code (null = auto-applied / no code)
  type             PromotionType   // PERCENT_OFF | AMOUNT_OFF | TRIAL_EXTENSION
  duration         PromotionDuration // ONCE | REPEATING | FOREVER

  // Discount details
  percentOff       Float?          // e.g. 20.0 for 20%
  amountOffCents   Int?            // Fixed amount in cents
  currency         String          @default("eur")
  durationInMonths Int?            // For REPEATING duration

  // Trial extension
  trialDays        Int?            // Extra trial days (for TRIAL_EXTENSION type)

  // Scope: null = applies to all products in this app
  productId        String?
  product          Product?        @relation(fields: [productId], references: [id])

  // Limits
  maxRedemptions   Int?            // null = unlimited
  expiresAt        DateTime?       // null = never expires

  // Stripe references (created on connected account)
  stripeCouponId   String?
  stripePromoCodeId String?

  status           PromotionStatus @default(ACTIVE)

  redemptions      PromotionRedemption[]

  @@unique([appId, code])
  @@index([appId])
  @@index([status])
}

model PromotionRedemption {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])

  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  @@index([promotionId])
  @@index([customerId])
}

enum PromotionType {
  PERCENT_OFF
  AMOUNT_OFF
  TRIAL_EXTENSION
}

enum PromotionDuration {
  ONCE
  REPEATING
  FOREVER
}

enum PromotionStatus {
  ACTIVE
  PAUSED
  EXPIRED
}

// Waitlist for coming-soon page
model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
