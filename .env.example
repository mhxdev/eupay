# ==============================================================================
# EUPay — Environment Variables
# ==============================================================================
# Copy this file to apps/web/.env.local for local development:
#   cp .env.example apps/web/.env.local
#
# For production (Vercel), set these in the Vercel dashboard under
# Settings > Environment Variables. See DEPLOYMENT.md for details.
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------

# PostgreSQL connection string.
# Local:      postgresql://postgres:password@localhost:5432/eupay
# Supabase:   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Neon:       postgresql://[user]:[password]@[host].neon.tech/eupay?sslmode=require
#
# In production, always use SSL (?sslmode=require) and connection pooling.
DATABASE_URL="postgresql://postgres:password@localhost:5432/eupay"

# ------------------------------------------------------------------------------
# STRIPE
# ------------------------------------------------------------------------------
# Get these from https://dashboard.stripe.com/apikeys
#
# Test keys start with sk_test_ / pk_test_ — use for development.
# Live keys start with sk_live_ / pk_live_ — use for production only.
# See DEPLOYMENT.md for the switchover checklist.

# Secret key — server-side only, NEVER expose to the client.
STRIPE_SECRET_KEY="sk_test_..."

# Publishable key — safe to expose in client-side code.
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook signing secret — from Stripe Dashboard > Developers > Webhooks.
# Local dev (Stripe CLI):   whsec_... (from `stripe listen --forward-to ...`)
# Production:               whsec_... (from the webhook endpoint you create in Stripe)
#
# The webhook endpoint URL is: https://your-domain.com/api/v1/webhooks/stripe
# Events to subscribe to:
#   checkout.session.completed
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_succeeded
#   invoice.payment_failed
#   charge.refunded
#   charge.dispute.created
STRIPE_WEBHOOK_SECRET="whsec_..."

# ------------------------------------------------------------------------------
# CLERK (Dashboard Authentication)
# ------------------------------------------------------------------------------
# Get these from https://dashboard.clerk.com → your app → API Keys.
#
# Clerk protects the /dashboard routes. API v1 routes use Bearer token auth
# (API keys from the dashboard), NOT Clerk.

# Publishable key — used client-side, safe to expose.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# Secret key — server-side only.
CLERK_SECRET_KEY="sk_test_..."

# Clerk redirect URLs (these rarely need changing).
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ------------------------------------------------------------------------------
# RESEND (Transactional Emails)
# ------------------------------------------------------------------------------
# Get your API key from https://resend.com/api-keys
# Verify your sending domain at https://resend.com/domains
#
# Email templates sent:
#   - PurchaseConfirmation  (after checkout.session.completed)
#   - WiderrufsrechtWaiver  (after checkout.session.completed, German law)
#   - CancellationConfirmation (after customer.subscription.deleted)

# API key for sending emails.
RESEND_API_KEY="re_..."

# Verified sender address. Must match a domain verified in Resend.
RESEND_FROM_EMAIL="receipts@eupay.io"

# ------------------------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------------------------

# Public-facing URL of this application.
# Local dev:   http://localhost:3000
# Production:  https://eupay.io  (or your Vercel domain)
#
# Used for Stripe Customer Portal return URLs and email links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Application secret — used for internal hashing/signing.
# Generate with: openssl rand -base64 32
APP_SECRET="generate-a-32-plus-char-random-string-here"
